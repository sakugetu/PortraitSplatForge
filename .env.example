OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-2
PORT=8787

# Optional production GS3D backends. Commands may use placeholders:
# {inputDir} {outputDir} {manifest} {quality} {jobId}
# The server also exposes these as GS3D_INPUT_DIR, GS3D_OUTPUT_DIR,
# GS3D_MANIFEST, GS3D_QUALITY, and GS3D_JOB_ID.
#
# Keep these blank until the corresponding external backend and model weights
# are installed locally. See THIRD_PARTY_NOTICES.md before enabling research
# models such as Apple SHARP.
SHARP_COMMAND=
SHARP_CONDA_ENV=sharp
SHARP_CHECKPOINT=
SHARP_ROTATE_Y_180=1
SHARP_MIRROR_X=1
SHARP_FILTER_BACKGROUND=1
SHARP_FILTER_MIN_LUMA=4
SHARP_FILTER_MAX_WHITE_LUMA=248
SHARP_FILTER_MAX_WHITE_CHROMA=7
SHARP_FILTER_KEY_MIN_R=210
SHARP_FILTER_KEY_MAX_G=70
SHARP_FILTER_KEY_MIN_B=210
SHARP_FILTER_KEY_SPILL_MIN_R=135
SHARP_FILTER_KEY_SPILL_MIN_B=135
SHARP_FILTER_KEY_SPILL_GREEN_RATIO=0.72
SHARP_FILTER_MIN_OPACITY=0.02
SHARP_FILTER_RADIUS_QUANTILE=0.992
SHARP_DENSIFY_FACTOR=2
SHARP_DENSIFY_JITTER=0.0018
GAUSSIAN_OBJECT_COMMAND=
INSTANTSPLAT_COMMAND=
INSTANTSPLAT_ROOT=
INSTANTSPLAT_CONDA_ENV=instantsplat
INSTANTSPLAT_ITERATIONS=
INSTANTSPLAT_RENDER_VIDEO=0
VGGT_GSPLAT_COMMAND=
VGGT_ROOT=
VGGT_CONDA_ENV=vggt
VGGT_PYTHON=
GSPLAT_ROOT=
GSPLAT_CONDA_ENV=gsplat-train
GSPLAT_PYTHON=
VGGT_USE_BA=0
VGGT_GSPLAT_SKIP_TRAIN=0
VGGT_GSPLAT_STEPS=
VGGT_POINT_FILTER=1
VGGT_FILTER_QUANTILE=
VGGT_FILTER_MAX_POINTS=
VGGT_GSPLAT_PROFILE=portrait
VGGT_GSPLAT_EXTRA_ARGS=
FOUR_VIEW_FUSION_COMMAND=
FOUR_VIEW_FUSION_SURFACE_MODE=direct
OPEN_SPLAT_COMMAND=
GSPLAT_COMMAND=
CUSTOM_GS3D_COMMAND=
GS3D_BACKEND_TIMEOUT_MS=10800000
GS3D_PREVIEW_POINTS=450000
GS3D_DENSE_PREVIEW_POINTS=900000
GS3D_FULL_PREVIEW_POINTS=3000000
GS3D_FLIP_EXTERNAL_Y=1
GS3D_PREPROCESS_SIZE=1536
GS3D_APPLY_INPUT_MASK=1
GS3D_MASK_MODE=refined
GS3D_SEGMENTER=rembg
GS3D_REMBG_PYTHON=.venv-rembg\Scripts\python.exe
GS3D_REMBG_MODEL=u2net_human_seg
GS3D_REMBG_PERSON_MODEL=u2net_human_seg
GS3D_REMBG_OBJECT_MODEL=isnet-general-use
GS3D_CROP_TO_MASK=1
GS3D_MASK_CROP_PADDING=0.08
GS3D_SHARP_BACKGROUND=key
GS3D_KEY_ALPHA_THRESHOLD=128
GS3D_AUGMENT_VIEWS=1
GS3D_AUGMENT_VIEW_COUNT=4
